# PostgreSQL — local install (default port 5432, no Docker required)
DB_NAME=sweats_ecommerce
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Production / staging (see docs/deploy.md)
# DJANGO_SECRET_KEY=generate-a-long-random-key
# DJANGO_DEBUG=false
# DATABASE_URL=postgresql://...   # set by Railway/Render
# DJANGO_ALLOWED_HOSTS=your-api.up.railway.app
# DJANGO_CORS_ORIGINS=https://your-app.vercel.app
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
# SERVE_MEDIA=true

# Demo / tunnel (optional — see docs/demo.md)
# DJANGO_ALLOWED_HOSTS=abc123.ngrok-free.app
# DJANGO_CORS_ORIGINS=https://xyz789.ngrok-free.app

# Frontend / payments (optional)
FRONTEND_URL=http://localhost:5173
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
PAYMENT_GATEWAY_MOCK=true

# Database backups (optional — defaults to project backup/ folder)
# BACKUP_DIR=D:/path/to/backup
# PG_DUMP_PATH=C:/Program Files/PostgreSQL/16/bin/pg_dump.exe
